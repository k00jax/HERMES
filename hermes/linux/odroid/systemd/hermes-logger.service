[Unit]
Description=HERMES Logger Daemon
After=network.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=odroid
WorkingDirectory=/home/odroid/hermes-src/hermes
ExecStart=/usr/bin/python3 -u /home/odroid/hermes-src/hermes/linux/logger/daemon.py
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
